#!/usr/bin/env bash
# Smoke-test the no-Docker, native-binaries deploy path.
#
# Runs the full smartchats stack as TWO child processes:
#   1. surreal           — native binary (install via curl … install.surrealdb.com)
#   2. smartchats-server — Express, via `bun` (runs src/cli.ts directly).
#                          Serves BOTH the API at /local-api/* AND the static
#                          SPA from apps/smartchats/out/. No Next.js runtime.
#
# Purpose: validate that the entire stack runs under Bun + native binaries,
# Docker-free, ahead of designing the `smartchats start` CLI command and the
# `curl | sh` install pipeline.
#
# Browser only ever hits port 3000 (Express). Same-origin everything.
#
# Usage:
#   bin/test-bun-deploy                Auto-detect: rebuild if any source under
#                                      apps/smartchats or packages/*/src is newer
#                                      than the build sentinel (apps/smartchats/out/
#                                      index.html); otherwise reuse the existing
#                                      build.
#   bin/test-bun-deploy --rebuild      Force `bun run build` even if artifacts
#                                      look fresh.
#   bin/test-bun-deploy --no-rebuild   Skip the mtime check; reuse whatever
#                                      artifacts exist (escape hatch for
#                                      intentionally running against a stale
#                                      build). Fails if artifacts are missing.
#   bin/test-bun-deploy --keep-data    Reuse the data dir from a prior run.
#   bin/test-bun-deploy --port <n>     Next.js port (default 3000).
#   bin/test-bun-deploy --data-dir <p> SurrealDB data dir (default ~/.smartchats/test-bun-deploy/data).
#   bin/test-bun-deploy --seed <path>  After schema is applied, import the given
#                                      .surql file into ns=smartchats db=main.
#                                      Used by benchpress; see packages/benchpress.
#   bin/test-bun-deploy --help

set -uo pipefail
source "$(dirname "$0")/_lib.sh"

# ── Defaults ──────────────────────────────────────────────────────────
APP_PORT=3000
SURREAL_PORT=8000
DATA_DIR="${HOME}/.smartchats/test-bun-deploy/data"
REBUILD=false
NO_REBUILD=false
KEEP_DATA=false
SEED_FILE=""

# ── Args ──────────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
    case "$1" in
        --rebuild)    REBUILD=true; shift ;;
        --no-rebuild) NO_REBUILD=true; shift ;;
        --keep-data)  KEEP_DATA=true; shift ;;
        --port)       APP_PORT="$2"; shift 2 ;;
        --data-dir)   DATA_DIR="$2"; shift 2 ;;
        --seed)       SEED_FILE="$2"; shift 2 ;;
        --help|-h)
            sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        *)  err "Unknown option: $1"; exit 1 ;;
    esac
done

if $REBUILD && $NO_REBUILD; then
    err "--rebuild and --no-rebuild are mutually exclusive."
    exit 1
fi

if [[ -n "$SEED_FILE" && ! -f "$SEED_FILE" ]]; then
    err "Seed file not found: $SEED_FILE"
    exit 1
fi

# ── Preflight ─────────────────────────────────────────────────────────
header "Preflight"

check_command bun || exit 1
info "bun: $(bun --version)"

# Surreal: PATH, then ~/.surrealdb/surreal, then /usr/local/bin/surreal.
SURREAL_BIN=""
if command -v surreal &>/dev/null; then
    SURREAL_BIN="$(command -v surreal)"
elif [[ -x "${HOME}/.surrealdb/surreal" ]]; then
    SURREAL_BIN="${HOME}/.surrealdb/surreal"
elif [[ -x "/usr/local/bin/surreal" ]]; then
    SURREAL_BIN="/usr/local/bin/surreal"
else
    err "surreal binary not found."
    err "Install: curl --proto '=https' --tlsv1.2 -sSf https://install.surrealdb.com | sh"
    exit 1
fi
info "surreal: $SURREAL_BIN ($("$SURREAL_BIN" version 2>&1 | head -1))"

cd "$REPO_ROOT"

# Provider keys from .env if present (so the agent can actually answer).
if [[ -f "$REPO_ROOT/.env" ]]; then
    set -a; source "$REPO_ROOT/.env"; set +a
    info ".env loaded from repo root"
fi

# ── Build (if needed) ─────────────────────────────────────────────────
# Two artifacts matter:
#   - apps/smartchats/out/  for the static SPA (Express serves it)
#   - packages/*/dist/      for workspace deps the local-server imports
#     (smartchats-database, smartchats-backend-local, etc.). The local-server
#     resolves these via package.json `main: dist/index.js`, so stale dist =
#     stale code even with bun running TS directly in the server itself.
#
# turbo handles dependency-ordering + caching, so the full root build is
# fast on subsequent runs (only changed packages re-emit).
#
# Auto-rebuild trigger: any source file newer than the SPA sentinel
# (apps/smartchats/out/app.html, regenerated every build). The previous
# behavior was "always reuse, pass --rebuild to force" — which silently ran
# tests against a stale binary whenever someone forgot the flag after
# editing source. --no-rebuild is the escape hatch when you actually want
# the stale build (e.g., comparing two binaries' behavior).
SPA_DIR="$REPO_ROOT/apps/smartchats/out"
DB_DIST="$REPO_ROOT/packages/smartchats-database/dist"
BUILD_SENTINEL="$SPA_DIR/app.html"

needs_rebuild=false
rebuild_reason=""
if $REBUILD; then
    needs_rebuild=true
    rebuild_reason="--rebuild flag"
elif $NO_REBUILD; then
    if [[ ! -d "$SPA_DIR" ]] || [[ ! -d "$DB_DIST" ]] || [[ ! -f "$BUILD_SENTINEL" ]]; then
        err "--no-rebuild set but build artifacts are missing. Run without --no-rebuild first."
        exit 1
    fi
elif [[ ! -d "$SPA_DIR" ]] || [[ ! -d "$DB_DIST" ]] || [[ ! -f "$BUILD_SENTINEL" ]]; then
    needs_rebuild=true
    rebuild_reason="artifacts missing"
else
    # Look for any TS/TSX/CSS source newer than the build sentinel. -path
    # prune skips node_modules / dist / .turbo / .next so we don't get
    # tripped up by build artifacts under packages/*. head -1 bails after
    # the first hit — cheap.
    newer_src=$(find "$REPO_ROOT/apps/smartchats/app" "$REPO_ROOT/apps/smartchats/src" \
        -type f \( -name "*.ts" -o -name "*.tsx" -o -name "*.css" \) \
        -newer "$BUILD_SENTINEL" -print 2>/dev/null | head -1)
    if [[ -z "$newer_src" ]]; then
        newer_src=$(find "$REPO_ROOT/packages" \
            \( -path "*/node_modules" -o -path "*/dist" -o -path "*/.turbo" -o -path "*/.next" \) -prune \
            -o -type f \( -name "*.ts" -o -name "*.tsx" \) -newer "$BUILD_SENTINEL" -print 2>/dev/null | head -1)
    fi
    if [[ -n "$newer_src" ]]; then
        needs_rebuild=true
        rebuild_reason="source newer than sentinel (${newer_src#$REPO_ROOT/})"
    fi
fi

if $needs_rebuild; then
    header "Building workspace (turbo run build) — $rebuild_reason"
    cd "$REPO_ROOT"
    PATH="$HOME/.bun/bin:$PATH" bun run build || { err "build failed"; exit 1; }
    ok "Workspace built"
else
    if $NO_REBUILD; then
        info "Reusing existing builds (--no-rebuild; skipped mtime check)"
    else
        info "Reusing existing builds (source matches artifact mtime)"
    fi
fi

# ── Data dir ──────────────────────────────────────────────────────────
if ! $KEEP_DATA && [[ -d "$DATA_DIR" ]]; then
    info "Wiping prior data dir: $DATA_DIR"
    rm -rf "$DATA_DIR"
fi
mkdir -p "$DATA_DIR"

# ── Process supervision ───────────────────────────────────────────────
PIDS=()

cleanup() {
    echo
    info "Shutting down..."
    for pid in "${PIDS[@]+"${PIDS[@]}"}"; do
        kill -TERM "$pid" 2>/dev/null || true
    done
    sleep 1
    for pid in "${PIDS[@]+"${PIDS[@]}"}"; do
        kill -KILL "$pid" 2>/dev/null || true
    done
}
trap cleanup INT TERM EXIT

# ── 1. SurrealDB ──────────────────────────────────────────────────────
header "Starting SurrealDB on 127.0.0.1:${SURREAL_PORT}"
"$SURREAL_BIN" start \
    --user root --pass root \
    --bind "127.0.0.1:${SURREAL_PORT}" \
    --log info \
    "rocksdb:${DATA_DIR}/surreal.db" &
PIDS+=($!)

for _ in {1..30}; do
    if curl -sf "http://127.0.0.1:${SURREAL_PORT}/health" >/dev/null 2>&1; then
        ok "SurrealDB ready"
        break
    fi
    sleep 1
done

# ── 2. smartchats-local-server: API + static SPA, on the app port ─────
# This single process replaces the old `Next.js (port 3000)` +
# `Express (port 4242)` split. The Express server now mounts the API at
# /local-api/* and serves the static export from apps/smartchats/out/.
header "Starting smartchats-local-server on 0.0.0.0:${APP_PORT} (API + SPA)"
export SURREAL_URL="ws://127.0.0.1:${SURREAL_PORT}/rpc"
export SURREAL_NS=smartchats SURREAL_DB=main
export SURREAL_USER=root SURREAL_PASSWORD=root
export SMARTCHATS_HOST=0.0.0.0
export SMARTCHATS_PORT=${APP_PORT}
export SMARTCHATS_STATIC_DIR="$SPA_DIR"

cd "$REPO_ROOT/packages/smartchats-local-server"
PATH="$HOME/.bun/bin:$PATH" bun --bun run src/cli.ts &
PIDS+=($!)
cd "$REPO_ROOT"

for _ in {1..30}; do
    if curl -sf "http://127.0.0.1:${APP_PORT}/local-api/health" >/dev/null 2>&1; then
        ok "smartchats-local-server ready"
        break
    fi
    sleep 1
done

# ── 3. Optional: import seed fixture ──────────────────────────────────
# Must run AFTER smartchats-local-server is healthy: the server applies
# the schema on boot, so importing before that would create rows against
# an empty namespace.
if [[ -n "$SEED_FILE" ]]; then
    SEED_ABS="$(cd "$(dirname "$SEED_FILE")" && pwd)/$(basename "$SEED_FILE")"
    header "Importing seed: $SEED_ABS"
    # `surreal sql` (not `surreal import`) — pipes a .surql file through the
    # /sql path so the schema's `VALUE time::now()` defaults for created_at /
    # updated_at still run. `surreal import` requires OPTION IMPORT;, which
    # disables field processing and would leave required datetime columns NONE.
    SEED_LINES=$(wc -l < "$SEED_ABS")
    if "$SURREAL_BIN" sql \
        --endpoint "ws://127.0.0.1:${SURREAL_PORT}" \
        --username root --password root \
        --namespace smartchats --database main \
        < "$SEED_ABS" > /tmp/benchpress_seed_load.log 2>&1; then
        if grep -qiE "error|failed" /tmp/benchpress_seed_load.log; then
            err "Seed import had errors — see /tmp/benchpress_seed_load.log"
            tail -20 /tmp/benchpress_seed_load.log >&2
            exit 1
        fi
        ok "Seed imported ($SEED_LINES statements)"
    else
        err "Seed import command failed"
        tail -20 /tmp/benchpress_seed_load.log >&2
        exit 1
    fi
fi

echo
ok "Stack up. Open: http://localhost:${APP_PORT}"
info "Express :${APP_PORT}  ↦  / (static SPA from $SPA_DIR) + /local-api/* (API) → SurrealDB :${SURREAL_PORT}"
info "Ctrl-C to stop."

wait -n
