{
  "name": "smartchats",
  "version": "0.1.0",
  "description": "SmartChats — one-stop CLI for the open-source voice AI agent. Launch the local docker stack (`smartchats launch`), verify it (`smartchats doctor`), sign in / login to the cloud SaaS, and import + export user data. Single entry point for end users and contributors.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "smartchats": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "smartchats",
    "ai-agent",
    "voice-ai",
    "llm",
    "cli",
    "self-hosted",
    "docker"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sheunaluko/smartchats.git",
    "directory": "packages/smartchats-cli"
  },
  "homepage": "https://github.com/sheunaluko/smartchats#readme",
  "bugs": "https://github.com/sheunaluko/smartchats/issues",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "consola": "^3.2.3",
    "smartchats-backend": "*",
    "smartchats-cloud-client": "*",
    "smartchats-database": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5"
  },
  "license": "Apache-2.0"
}
