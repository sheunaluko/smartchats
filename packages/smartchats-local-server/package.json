{
  "name": "smartchats-local-server",
  "version": "0.1.0",
  "description": "Self-hosted Express server for SmartChats \u2014 serves the SmartChats HTTP backend against a local SurrealDB and BYO API keys",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "smartchats-local-server": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "smartchats-backend": "*",
    "smartchats-database": "*",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "openai": "^4.72.0",
    "consola": "^3.2.3",
    "jsdom": "^24.0.0",
    "@mozilla/readability": "^0.5.0",
    "tiktoken": "^1.0.21",
    "cortex": "*",
    "llm-service": "*"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/jsdom": "^21.1.6",
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5"
  },
  "license": "Apache-2.0"
}
