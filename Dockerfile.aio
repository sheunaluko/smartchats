# SmartChats — all-in-one image (AIO).
#
# Single container running surreal + smartchats-server (which serves the SPA
# at / and the API at /local-api/*). Browser only ever talks to port 3000.
#
# Implementation: runs the standard `curl | bash` install path against a
# fresh Debian, then ENTRYPOINTs `smartchats start --foreground`. Same code
# path as a bare-metal install — the image build is also a smoke test of
# the installer.
#
# Build:
#   docker build -f Dockerfile.aio -t smartchats-aio:latest .
#
# Run (env-file form, recommended for production):
#   docker run --rm -p 3000:3000 \
#     -v ~/.smartchats/data:/data \
#     --env-file .env \
#     smartchats-aio:latest
#
# Run (flag form, easier for one-offs):
#   docker run --rm -p 3000:3000 \
#     -e OPENAI_API_KEY=$OPENAI_API_KEY \
#     -v ~/.smartchats/data:/data \
#     smartchats-aio:latest

FROM debian:bookworm-slim

# tini for clean PID 1 signal handling; ca-certificates + curl for the
# installer's download step. SurrealDB ships statically linked so no
# additional deps needed.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        tini ca-certificates curl tar \
    && rm -rf /var/lib/apt/lists/*

# Allow override of the installer source at build time. Three knobs:
#   SMARTCHATS_INSTALL_URL    Where to fetch install.sh from.
#   SMARTCHATS_INSTALL_BASE   Where install.sh fetches the release tarball
#                             from (passed through as env, install.sh reads it).
#   SMARTCHATS_VERSION        Pin a specific release tag (default: latest).
#
# Production builds use the defaults. scripts/test-install.sh overrides
# both URLs to point at a local HTTP server, so the same Dockerfile and
# same install.sh are exercised against locally-built artifacts — image
# build IS the install regression test.
ARG SMARTCHATS_VERSION=latest
ARG SMARTCHATS_INSTALL_URL=https://smartchats.ai/install
ARG SMARTCHATS_INSTALL_BASE=https://github.com/sheunaluko/smartchats/releases

# Install. --non-interactive skips the setup prompts (no TTY in docker
# build); --no-path skips the rc-file edits (the ENTRYPOINT uses the full
# binary path so PATH doesn't need to be wired).
RUN curl -fsSL "${SMARTCHATS_INSTALL_URL}" \
    | SMARTCHATS_INSTALL_BASE="${SMARTCHATS_INSTALL_BASE}" \
      bash -s -- --non-interactive --no-path --version "${SMARTCHATS_VERSION}"

# Persistent volume for SurrealDB rocksdb store.
VOLUME ["/data"]

EXPOSE 3000

# Foreground + explicit data-dir so docker can see the process tree and
# the rocksdb store lands on the mounted volume.
ENTRYPOINT ["/usr/bin/tini", "--", \
            "/root/.smartchats/bin/smartchats", "start", \
            "--data-dir=/data", "--foreground"]
