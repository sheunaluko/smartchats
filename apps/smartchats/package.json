{
  "name": "smartchats-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "predev": "npm run prebuild",
    "dev:https": "next dev -p 3000 --experimental-https --experimental-https-key ./localhost+1-key.pem --experimental-https-cert ./localhost+1.pem",
    "predev:https": "npm run prebuild",
    "type-check": "tsc --noEmit --project tsconfig.json",
    "prebuild": "node scripts/prebuild.mjs all",
    "prebuild:site": "node scripts/prebuild.mjs site",
    "prebuild:assets": "node scripts/prebuild.mjs assets",
    "cleanup-onnx": "node scripts/prebuild.mjs cleanup-onnx",
    "build": "next build",
    "start": "next start",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
