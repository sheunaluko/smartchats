/**
 * Onboarding Module — Explainer functions + agentic onboarding flow.
 *
 * State lives in the KG (durable) with an in-memory cache from prefetch.
 * beforeBuild() reads the cache and sets trailing state so the agent
 * knows whether to offer onboarding, which steps remain, etc.
 *
 * Each explain_* function:
 *   1. Sets shell to 'guided' mode (medium orb + transcript + response + viz)
 *   2. Pushes a custom visualization
 *   3. Speaks intro text via user_output (no LLM round-trip)
 *   4. Marks the step complete in cache + KG
 */

import { useSmartChatsStore } from '../store/useSmartChatsStore'
import { prefetchStartup } from './initialization'

// ── In-memory onboarding cache (populated from prefetch KG data) ──

interface OnboardingCache {
    status: 'not_started' | 'in_progress' | 'complete' | 'skipped'
    completed_steps: string[]
    pendingCompletion: string | null
    user_name: string | null
    hydrated: boolean
}

const STEPS = ['voice', 'personalization', 'metrics', 'logs', 'accumulate_text', 'apps', 'ui_tour', 'appearance', 'conclusion'] as const

let _cache: OnboardingCache = {
    status: 'not_started',
    completed_steps: [],
    pendingCompletion: null,
    user_name: null,
    hydrated: false,
}

// Hydrate cache from prefetched KG data (resolves immediately if already fetched)
prefetchStartup().then((data: any) => {
    const kg = data?.current_user_kg || ''
    if (!kg) { _cache.hydrated = true; return }

    // Parse onboarding → complete → step entries
    const completeMatches = kg.matchAll(/onboarding.*?complete.*?(\w+)/gi)
    for (const m of completeMatches) {
        const step = m[1].toLowerCase()
        if (step === 'skipped') {
            _cache.status = 'skipped'
        } else if ((STEPS as readonly string[]).includes(step) && !_cache.completed_steps.includes(step)) {
            _cache.completed_steps.push(step)
        }
    }
    if (_cache.status !== 'skipped') {
        _cache.status = STEPS.every(s => _cache.completed_steps.includes(s)) ? 'complete'
            : _cache.completed_steps.length > 0 ? 'in_progress' : 'not_started'
    }

    // Extract user name
    const nameMatch = kg.match(/name_is[:\s]+([^\n,)]+)/i)
    if (nameMatch) {
        _cache.user_name = nameMatch[1].trim()
    }

    _cache.hydrated = true
}).catch(() => { _cache.hydrated = true })

/** Flush any pending completion to KG, then set the new pending step */
async function startStep(step: string, ops: any) {
    // Always mark in_progress as soon as any step starts
    _cache.status = 'in_progress'
    // Flush prior pending step → mark it complete in KG
    if (_cache.pendingCompletion && !_cache.completed_steps.includes(_cache.pendingCompletion)) {
        _cache.completed_steps.push(_cache.pendingCompletion)
        await persistStepComplete(_cache.pendingCompletion, ops)
    }
    // Set this step as pending
    _cache.pendingCompletion = step
}

/** Flush pending + mark current step complete (for final steps like conclusion) */
async function finishOnboarding(ops: any) {
    // Flush pending
    if (_cache.pendingCompletion && !_cache.completed_steps.includes(_cache.pendingCompletion)) {
        _cache.completed_steps.push(_cache.pendingCompletion)
        await persistStepComplete(_cache.pendingCompletion, ops)
    }
    _cache.pendingCompletion = null
    _cache.status = 'complete'
}

/** Persist a completed step as a KG triple: onboarding → complete → step */
async function persistStepComplete(step: string, ops: any) {
    const store = useSmartChatsStore.getState()
    const storeFn = store.agent?.function_dictionary?.store_declarative_knowledge
    if (storeFn) {
        await storeFn.fn({
            params: { triples: [['onboarding', 'complete', step]] },
            util: ops.util,
        }).catch(() => {})
    }
}

/**
 * Shared return value for all explainer functions.
 * Tells the agent that the explainer already spoke to the user
 * and it should NOT generate additional speech — just wait for user input.
 */
const EXPLAINER_RESULT = {
    ok: true,
    spoken: true,
    instruction: 'STOP THE LOOP NOW. The explainer has already spoken. Return response=null, code=null. Do NOT call another explainer. Do NOT generate any text. Exit the execution loop and wait for user input.',
}

// ── System message ──

const ONBOARDING_SYSTEM_MSG = `[Onboarding]
Check the trailing onboarding state to decide what to do:
- If status is "not_started": on first turn, call voice_interaction_explainer immediately. Do NOT greet the user first — the explainer handles the greeting.
- If status is "in_progress": check current_step and remaining_steps. The current_step has ALREADY been presented — do NOT re-run it. Call the FIRST item in remaining_steps. Steps in order: voice, personalization, metrics, logs, accumulate_text, apps, ui_tour, appearance, conclusion.
- If status is "complete" or "skipped": do nothing — behave normally.
- If the user asks to skip, call skip_onboarding immediately.

CRITICAL RULES:
- Call exactly ONE explainer per user turn. After calling it, STOP your execution loop — return a null response with no code. Do NOT call the next explainer in the same turn. Wait for the user to speak.
- The explainer ALREADY spoke to the user via TTS. Your response for that turn MUST be empty/null.
- Do NOT narrate, acknowledge, or repeat what the explainer said. Produce ZERO words.
- Do NOT say things like "the explainer already spoke" — that IS speaking.
- Do NOT introduce or preview the next section. Never say "Next is X" or "Next up is Y" — just call the explainer function directly with a null/silent response. The explainer introduces itself.
- ONLY advance to the next explainer when the user explicitly says "proceed", "next", "continue", "next step", or similar. For ANY other user input (questions, comments, requests), respond normally in ONE brief sentence — do NOT auto-advance. The user controls the pace.
- During the accumulate_text step: if the user says "create a test log" or similar, you MUST use the accumulate_text function (that's the whole point — they're testing it). Do not use save_log directly. Call accumulate_text with user_instructions like "Collecting test log. Say finished when done." and stay silent. After the user finishes, do NOT save the log — it is only a demo. Just acknowledge and offer to proceed.

IMPORTANT — when storing the user's name in the knowledge graph:
- Use exactly: store_declarative_knowledge({ triples: [["current_user", "name_is", "<their name>"]] })
- The subject MUST be "current_user", NOT the user's actual name.`

// ── Module ──

export function createOnboardingModule() {
    const mod = {
        id: 'onboarding',
        name: 'Onboarding',
        position: 95,
        system_msg: '',
        state: '',

        beforeBuild() {
            // Set system_msg only if onboarding is relevant
            if (_cache.status === 'complete' || _cache.status === 'skipped') {
                mod.system_msg = ''
                mod.state = ''
                return
            }

            mod.system_msg = ONBOARDING_SYSTEM_MSG

            // Include pending step as "done" for the agent's view — it's been started even if not yet flushed to KG
            const effectiveCompleted = _cache.pendingCompletion && !_cache.completed_steps.includes(_cache.pendingCompletion)
                ? [..._cache.completed_steps, _cache.pendingCompletion]
                : _cache.completed_steps
            const remaining = STEPS.filter(s => !effectiveCompleted.includes(s))
            mod.state = [
                `onboarding_status: ${_cache.status}`,
                `completed_steps: ${effectiveCompleted.length > 0 ? effectiveCompleted.join(', ') : 'none'}`,
                `current_step: ${_cache.pendingCompletion || 'none'}`,
                `remaining_steps: ${remaining.length > 0 ? remaining.join(', ') : 'none'}`,
                `user_name: ${_cache.user_name || 'unknown'}`,
            ].join('\n')
        },

        functions: [
            // ── Skip onboarding ──
            {
                enabled: true,
                name: 'skip_onboarding',
                description: 'Skip the onboarding flow. Call when the user asks to skip or says they don\'t need onboarding.',
                parameters: {},
                fn: async (ops: any) => {
                    ops.util.log('User skipped onboarding')
                    // Flush any pending step
                    if (_cache.pendingCompletion && !_cache.completed_steps.includes(_cache.pendingCompletion)) {
                        _cache.completed_steps.push(_cache.pendingCompletion)
                        await persistStepComplete(_cache.pendingCompletion, ops)
                    }
                    _cache.pendingCompletion = null
                    _cache.status = 'skipped'
                    await persistStepComplete('skipped', ops)
                    useSmartChatsStore.getState().setShellMode('full')
                    return { ok: true, skipped: true }
                },
                return_type: 'any',
            },
            // ── Reset onboarding ──
            {
                enabled: true,
                name: 'reset_onboarding',
                description: 'Reset onboarding to not_started. Deletes onboarding KG entries. Call when user asks to redo or reset onboarding.',
                parameters: {},
                fn: async (ops: any) => {
                    ops.util.log('Resetting onboarding state')
                    _cache.status = 'not_started'
                    _cache.completed_steps = []
                    _cache.user_name = null
                    const store = useSmartChatsStore.getState()
                    const deleteFn = store.agent?.function_dictionary?.delete_declarative_knowledge
                    if (deleteFn) {
                        // Delete the onboarding entity and all its relations
                        await deleteFn.fn({
                            params: { entity: 'onboarding' },
                            util: ops.util,
                        }).catch(() => {})
                        // Delete the current_user → doing → onboarding edge
                        await deleteFn.fn({
                            params: { triples: [['current_user', 'doing', 'onboarding']] },
                            util: ops.util,
                        }).catch(() => {})
                        // Clean up old-format triples from prior implementations
                        for (const kind of ['__onboarding', 'onboarding_status', 'onboarding_completed', 'onboarding_step']) {
                            await deleteFn.fn({
                                params: { triples: [['current_user', kind, '']] },
                                util: ops.util,
                            }).catch(() => {})
                        }
                        // Clean up orphaned entities
                        for (const entity of ['in_progress', 'not_started', 'complete', 'skipped', '__onboarding']) {
                            await deleteFn.fn({
                                params: { entity },
                                util: ops.util,
                            }).catch(() => {})
                        }
                    }
                    store.setShellMode('full')
                    return { ok: true, reset: true, status: 'not_started' }
                },
                return_type: 'any',
            },

            // ── Explainers ──
            {
                enabled: true,
                name: 'voice_interaction_explainer',
                description: 'Explain voice interaction and show the voice calibration tool.',
                parameters: {},
                fn: async (ops: any) => {
                    const { event, user_output } = ops.util
                    await startStep('voice', ops)
                    useSmartChatsStore.getState().setShellMode('guided')
                    event({ type: 'clear_visualizations' })
                    event({ type: 'visualization_update', vizType: 'calibration', props: {} })

                    // Store the doing → onboarding triple so it appears in KG
                    const storeFn = useSmartChatsStore.getState().agent?.function_dictionary?.store_declarative_knowledge
                    if (storeFn) {
                        await storeFn.fn({
                            params: { triples: [['current_user', 'doing', 'onboarding']] },
                            util: ops.util,
                        }).catch(() => {})
                    }

                    const text = `Hello! I am SmartChats, an advanced AI software for helping you achieve your goals. I have many features and would love to explain some of them and show you how to use me. The most important thing to know first is how to use the voice interaction. You can interrupt me or change my voice just by asking. Please speak in clear sentences and pause until you hear my acknowledgement sound, then wait for my response. If I don't hear you, try speaking in a full sentence instead of single word. Ask me any question, and then try to interrupt me. If it works, proceed. If not, please use the voice calibration below.`
                    await user_output(text)
                    return EXPLAINER_RESULT
                },
                return_type: 'any',
            },
            {
                enabled: true,
                name: 'personalization_explainer',
                description: 'Explain personalization and the knowledge graph. Shows a live star graph.',
                parameters: {},
                fn: async (ops: any) => {
                    const { event, user_output } = ops.util
                    await startStep('personalization', ops)
                    useSmartChatsStore.getState().setShellMode('guided')
                    event({ type: 'clear_visualizations' })
                    event({
                        type: 'visualization_update',
                        vizType: 'star_graph',
                        vizId: 'onboarding_kg',
                        props: {
                            rootId: 'current_user',
                            rootLabel: 'current_user',
                            seeds: [
                                { subject: 'current_user', predicate: 'doing', object: 'onboarding' },
                                ..._cache.completed_steps.map(s => ({ subject: 'onboarding', predicate: 'complete', object: s })),
                            ],
                        },
                    })

                    const text = `You can personalize SmartChats over time using your built-in private knowledge graph. You can add to the knowledge graph by telling me whatever you want. I'll remember your preferences, interests, and anything you share with me. What should I call you? Add your name and any other info now then lets proceed to move to the next onboarding step.`
                    await user_output(text)
                    return EXPLAINER_RESULT
                },
                return_type: 'any',
            },
            {
                enabled: true,
                name: 'metrics_explainer',
                description: 'Explain quantitative metric tracking and show example graphs.',
                parameters: {},
                fn: async (ops: any) => {
                    const { event, user_output } = ops.util
                    await startStep('metrics', ops)
                    useSmartChatsStore.getState().setShellMode('guided')
                    event({ type: 'clear_visualizations' })

                    event({
                        type: 'visualization_update', vizType: 'line_chart',
                        props: {
                            title: 'Weekly Meditation (minutes)',
                            series: [{
                                label: 'Minutes', color: '#6366f1',
                                points: [
                                    { x: 'Week 1', y: 10 }, { x: 'Week 2', y: 15 },
                                    { x: 'Week 3', y: 12 }, { x: 'Week 4', y: 20 },
                                    { x: 'Week 5', y: 25 }, { x: 'Week 6', y: 22 },
                                    { x: 'Week 7', y: 30 }, { x: 'Week 8', y: 35 },
                                ],
                            }],
                            yLabel: 'minutes',
                        },
                    })
                    event({
                        type: 'visualization_update', vizType: 'bar_chart',
                        props: {
                            title: 'Monthly Workouts',
                            items: [
                                { label: 'Jan', value: 8, color: '#22c55e' },
                                { label: 'Feb', value: 12, color: '#22c55e' },
                                { label: 'Mar', value: 15, color: '#22c55e' },
                                { label: 'Apr', value: 11, color: '#22c55e' },
                                { label: 'May', value: 18, color: '#6366f1' },
                                { label: 'Jun', value: 20, color: '#6366f1' },
                            ],
                            unit: 'sessions',
                        },
                    })
                    event({
                        type: 'visualization_update', vizType: 'stat_card',
                        props: { label: 'Current Streak', value: '14 days', delta: '+5 from last month', deltaDirection: 'up' },
                    })

                    const text = `In addition to knowledge, I can store quantitative metrics for you to track your progress on your goals, like workouts, healthy eating, or time spent with your family or any particular activity. Keeping track of your progress and getting clear visual feedback is key to motivation and success! We store metrics just by talking, and you can review graphs of your progress like the ones below! What are some things you'd like to track going forward? We can store or prepare them now so I remind you later. Otherwise we can continue and come back to that anytime.`
                    await user_output(text)
                    return EXPLAINER_RESULT
                },
                return_type: 'any',
            },
            {
                enabled: true,
                name: 'logs_explainer',
                description: 'Explain diary and log entries. Shows a star graph of log categories.',
                parameters: {},
                fn: async (ops: any) => {
                    const { event, user_output } = ops.util
                    await startStep('logs', ops)
                    useSmartChatsStore.getState().setShellMode('guided')
                    event({ type: 'clear_visualizations' })
                    const logSeeds = [
                        ..._cache.completed_steps.map(s => ({ subject: 'onboarding', predicate: 'complete', object: s })),
                        { subject: 'onboarding', predicate: 'section', object: 'Logs' },
                        { subject: 'Logs', predicate: 'category', object: 'Daily Journal' },
                        { subject: 'Logs', predicate: 'category', object: 'Dreams' },
                        { subject: 'Logs', predicate: 'category', object: 'Health Notes' },
                        { subject: 'Logs', predicate: 'category', object: 'Ideas' },
                        { subject: 'Logs', predicate: 'category', object: 'Gratitude' },
                    ]
                    event({
                        type: 'visualization_update', vizType: 'star_graph', vizId: 'onboarding_logs',
                        props: {
                            rootId: 'onboarding', rootLabel: 'onboarding', staggerMs: 2000,
                            seeds: logSeeds,
                        },
                    })

                    const text = `If you just want to create diary or log entries, you can do that by asking me to create a log with a particular category, for example, Daily Journal. All your logs are stored by category and searchable using advanced techniques, allowing you to instantly recall that memory from long ago! You can ask me things like, "What was the name of that restaurant I tried last week" or "Retrieve all my healthy eating logs and tell me how Ive been doing". We can prepare some log categories now if you want, or proceed to the next section.`
                    await user_output(text)
                    return EXPLAINER_RESULT
                },
                return_type: 'any',
            },
            {
                enabled: true,
                name: 'accumulate_text_explainer',
                description: 'Explain the accumulate text function for dictating logs. The explainer already tells the user how it works and to try "Create a test log". When the user says that, call accumulate_text with user_instructions "Collecting test log entry. Say finished when done." Do NOT repeat the instructions — the explainer already explained everything. Just silently start accumulate_text.',
                parameters: {},
                fn: async (ops: any) => {
                    const { event, user_output } = ops.util
                    await startStep('accumulate_text', ops)
                    useSmartChatsStore.getState().setShellMode('guided')
                    event({ type: 'clear_visualizations' })

                    const text = `I have a special function called Accumulate Text. This is helpful for storing your log entries. You can speak one or two sentences at a time and I will give you feedback that I heard you with a sound. Then continue dictating bit by bit and waiting for the sound. When you are done you say finished and I collect all the text. Try it by saying, Create a test log.`
                    await user_output(text)
                    return EXPLAINER_RESULT
                },
                return_type: 'any',
            },
            {
                enabled: true,
                name: 'apps_explainer',
                description: 'Explain the built-in app ecosystem. Shows a star graph of available apps.',
                parameters: {},
                fn: async (ops: any) => {
                    const { event, user_output } = ops.util
                    await startStep('apps', ops)
                    useSmartChatsStore.getState().setShellMode('guided')
                    event({ type: 'clear_visualizations' })
                    const appSeeds = [
                        ..._cache.completed_steps.map(s => ({ subject: 'onboarding', predicate: 'complete', object: s })),
                        { subject: 'onboarding', predicate: 'section', object: 'Apps' },
                        { subject: 'Apps', predicate: 'app', object: 'Log Explorer' },
                        { subject: 'Apps', predicate: 'app', object: 'Metrics Explorer' },
                        { subject: 'Apps', predicate: 'app', object: 'Knowledge Graph Explorer' },
                        { subject: 'Apps', predicate: 'app', object: 'Todo List' },
                    ]
                    event({
                        type: 'visualization_update', vizType: 'star_graph', vizId: 'onboarding_apps',
                        props: {
                            rootId: 'onboarding', rootLabel: 'onboarding', staggerMs: 2000,
                            seeds: appSeeds,
                        },
                    })

                    const text = `SmartChats also has built-in apps for managing your todo list and for reviewing your metrics and logs. Just ask me to open any of them! You can see the available apps appearing below. You can create and manage todo items with only your voice`
                    await user_output(text)
                    return EXPLAINER_RESULT
                },
                return_type: 'any',
            },
            {
                enabled: true,
                name: 'ui_tour_explainer',
                description: 'Run the mobile shell UI tour. Highlights key UI elements with explanations. The user taps to advance through each highlight.',
                parameters: {},
                fn: async (ops: any) => {
                    const { user_output } = ops.util
                    await startStep('ui_tour', ops)
                    const store = useSmartChatsStore.getState()
                    store.setShellMode('full')

                    const text = `Let me quickly show you the key parts of the interface. Say proceed when done.`
                    await user_output(text)

                    // Run the tour — resolves when user taps through all highlights
                    await store.mobileShellUiTour()
                    return EXPLAINER_RESULT
                },
                return_type: 'any',
            },
            {
                enabled: true,
                name: 'appearance_explainer',
                description: 'Explain theme customization. Shows a star graph of available themes.',
                parameters: {},
                fn: async (ops: any) => {
                    const { event, user_output } = ops.util
                    await startStep('appearance', ops)
                    useSmartChatsStore.getState().setShellMode('guided')
                    event({ type: 'clear_visualizations' })

                    const themeSeeds = [
                        ..._cache.completed_steps.map(s => ({ subject: 'onboarding', predicate: 'complete', object: s })),
                        { subject: 'onboarding', predicate: 'section', object: 'Themes' },
                        { subject: 'Themes', predicate: 'theme', object: 'Default' },
                        { subject: 'Themes', predicate: 'theme', object: 'Midnight' },
                        { subject: 'Themes', predicate: 'theme', object: 'Neon Terminal' },
                        { subject: 'Themes', predicate: 'theme', object: 'Zen' },
                        { subject: 'Themes', predicate: 'theme', object: 'Aurora' },
                        { subject: 'Themes', predicate: 'theme', object: 'Brutalist' },
                        { subject: 'Themes', predicate: 'theme', object: 'Crypto Gold' },
                        { subject: 'Themes', predicate: 'theme', object: 'Creative' },
                        { subject: 'Themes', predicate: 'theme', object: 'OLED Black' },
                        { subject: 'Themes', predicate: 'theme', object: 'Dev Tools' },
                    ]
                    event({
                        type: 'visualization_update', vizType: 'star_graph', vizId: 'onboarding_themes',
                        props: {
                            rootId: 'onboarding', rootLabel: 'onboarding', staggerMs: 1500,
                            seeds: themeSeeds,
                        },
                    })

                    const text = `You can customize the appearance of the user interface by asking me to change the theme or doing it yourself in settings. Try saying, activate neon terminal theme with dark mode. Say proceed when done.`
                    await user_output(text)
                    return EXPLAINER_RESULT
                },
                return_type: 'any',
            },
            {
                enabled: true,
                name: 'conclusion_explainer',
                description: 'Wrap up onboarding with a closing message. Call this as the final onboarding step.',
                parameters: {},
                fn: async (ops: any) => {
                    const { user_output } = ops.util
                    useSmartChatsStore.getState().setShellMode('full')

                    const text = `Thanks so much for trying SmartChats! Please see smartchats.ai/docs for more information and resources. I'm here whenever you need me.`
                    await user_output(text)

                    await finishOnboarding(ops)
                    return EXPLAINER_RESULT
                },
                return_type: 'any',
            },
        ],
    }

    return mod
}
